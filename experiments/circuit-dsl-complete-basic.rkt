#lang racket/base

;; ============================================
;; 电路DSL - 基础元件完整版
;; 支持8种常用元件，保持极简语法
;; ============================================

(require syntax/parse
         racket/struct
         racket/format
         racket/file
         racket/string)

;; ==================== 核心数据结构 ====================
(struct circuit (name title analysis components probes) 
  #:transparent
  #:methods gen:custom-write
  [(define (write-proc c port mode)
     (fprintf port "#<circuit:~a>" (circuit-name c)))])

(struct component (type id value nodes options) #:transparent)
(struct probe (type name node) #:transparent)

;; ==================== 语法类定义 ====================
(begin-for-syntax
  (define-syntax-class node
    #:description "电路节点（数字或符号）"
    (pattern (~or n:number n:symbol)))
  
  (define-syntax-class comp
    #:description "电路元件"
    (pattern (type:id id:id val:expr (nodes n1:node n2:node) 
             (~optional (~seq #:options opts:expr) #:defaults ([opts #'()])))))
  
  (define-syntax-class prb
    #:description "探测点"
    (pattern (probe-type:id probe-name:id nd:node))))

;; ==================== 核心宏：define-circuit ====================
(define-syntax (define-circuit stx)
  (syntax-parse stx
    [(_ name:id
        (~alt
         (~optional (~seq #:title title:expr) 
                    #:defaults ([title #'"Unnamed Circuit"]))
         (~optional (~seq #:analysis analysis:expr)
                    #:defaults ([analysis #'(dc)])))
        (~or comp:comp ...)
        (~or prb:prb ...))
     
     #`(define name
         (circuit
          'name
          #,title
          #,analysis
          (list (component 'comp.type 'comp.id comp.val 
                           (list comp.n1 comp.n2) comp.opts) ...)
          (list (probe 'prb.probe-type 'prb.probe-name prb.nd) ...)))]))

;; ==================== 基础验证系统 ====================
(define (validate-circuit circ)
  (printf "🔍 验证电路 ~a ...\n" (circuit-name circ))
  
  ;; 1. 节点检查
  (define nodes (remove-duplicates
                 (apply append (map component-nodes (circuit-components circ)))))
  (printf " ✓ 发现 ~a 个节点: ~a\n" (length nodes) nodes)
  
  ;; 2. 接地检查
  (unless (member 0 nodes)
    (printf " ⚠️ 警告：电路没有接地节点（节点0）\n"))
  
  ;; 3. 参数范围检查
  (for ([c (circuit-components circ)])
    (define val (component-value c))
    (when (and (number? val) (<= val 0))
      (error 'validate-circuit 
             "元件 ~a 值必须 > 0，当前为 ~a" 
             (component-id c) val)))
  
  ;; 4. 元件类型检查
  (for ([c (circuit-components circ)])
    (case (component-type c)
      [(mosfet)
       (unless (assoc '#:type (component-options c))
         (error 'validate-circuit "MOSFET ~a 必须指定 #:type nmos/pmos" 
                (component-id c)))]
      [(opamp)
       (unless (= (length (component-nodes c)) 3)
         (error 'validate-circuit "运算放大器 ~a 需要3个节点（- + 输出）" 
                (component-id c)))]))
  
  (printf "✅ 基础验证通过\n")
  circ)

;; ==================== SPICE生成器（完整支持8种元件） ====================
(define (generate-spice circ filename)
  (with-output-to-file filename #:exists 'replace
    (λ ()
      (printf "* SPICE netlist generated by Racket DSL\n")
      (printf "* Circuit: ~a\n" (circuit-title circ))
      (printf "* Analysis: ~a\n\n" (circuit-analysis circ))
      
      ;; 生成所有元件
      (for ([c (circuit-components circ)])
        (define n1 (first (component-nodes c)))
        (define n2 (second (component-nodes c)))
        (define n3 (if (> (length (component-nodes c)) 2)
                       (third (component-nodes c))
                       #f))
        
        (case (component-type c)
          [(vsource)
           (printf "V~a ~a ~a DC ~a\n" (component-id c) n1 n2 (component-value c))]
          [(resistor)
           (printf "R~a ~a ~a ~a\n" (component-id c) n1 n2 (component-value c))]
          [(capacitor)
           (printf "C~a ~a ~a ~a\n" (component-id c) n1 n2 (component-value c))]
          [(inductor)
           (printf "L~a ~a ~a ~a\n" (component-id c) n1 n2 (component-value c))]
          [(diode)
           (printf "D~a ~a ~a Ddefault\n" (component-id c) n1 n2)]
          [(opamp)
           (printf "X~a ~a ~a ~a opamp\n" (component-id c) n1 n2 n3)]
          [(switch)
           (printf "S~a ~a ~a ~a 0 SW\n" (component-id c) n1 n2 n1)]
          [(mosfet)
           (define mos-type (if (eq? (cadr (assoc '#:type (component-options c))) 'nmos)
                                "nmos" "pmos"))
           (printf "M~a ~a ~a ~a 0 ~a\n" (component-id c) n1 n2 n3 mos-type)]))
      
      ;; 生成探测点
      (for ([p (circuit-probes circ)])
        (printf ".probe v(~a)\n" (probe-node p)))
      
      ;; 生成分析命令
      (match (car (circuit-analysis circ))
        ['dc (printf "\n.op\n")]
        ['transient 
         (define stop-time (cadr (assoc '#:stop-time (cdr (circuit-analysis circ)))))
         (printf "\n.tran 1e-6 ~a\n" (or stop-time 0.01))]
        ['ac
         (define freq-range (cadr (assoc '#:freq-range (cdr (circuit-analysis circ)))))
         (printf "\n.ac dec 10 ~a ~a\n" (first freq-range) (second freq-range))])
      
      (printf ".end\n")))
  (printf "📄 SPICE netlist 已生成 → ~a\n" filename))

;; ==================== C++生成器（基础MNA框架） ====================
(define (generate-cpp-simulator circ filename)
  (with-output-to-file filename #:exists 'replace
    (λ ()
      (printf "// C++ circuit simulator - Generated by Racket DSL\n")
      (printf "// Circuit: ~a\n\n" (circuit-title circ))
      
      (printf "#include <iostream>\n")
      (printf "#include <vector>\n")
      (printf "#include <map>\n")
      (printf "#include <cmath>\n\n")
      
      (printf "class ~a {\n" (string-titlecase (symbol->string (circuit-name circ))))
      (printf "public:\n")
      (printf "  static constexpr const char* name = \"~a\";\n\n" (circuit-name circ))
      
      ;; 计算节点映射
      (define nodes (remove-duplicates
                     (apply append (map component-nodes (circuit-components circ)))))
      (define node-map (make-hash))
      (for ([node nodes] [i (in-naturals)])
        (hash-set! node-map node i))
      
      (printf "  // 节点映射\n")
      (printf "  std::map<int, size_t> node_index = {\n")
      (for ([(node idx) (in-hash node-map)])
        (printf "    {~a, ~a},\n" node idx))
      (printf "  };\n\n")
      
      (printf "  // 电路矩阵\n")
      (printf "  std::vector<std::vector<double>> G;\n")
      (printf "  std::vector<double> b;\n")
      (printf "  std::vector<double> x;\n\n")
      
      (printf "  void initialize() {\n")
      (printf "    size_t n = ~a;\n" (length nodes))
      (printf "    G.assign(n, std::vector<double>(n, 0.0));\n")
      (printf "    b.assign(n, 0.0);\n")
      (printf "    x.assign(n, 0.0);\n")
      (printf "  }\n\n")
      
      (printf "  void stamp_component(const std::string& type, \n")
      (printf "                      const std::string& id,\n")
      (printf "                      double value,\n")
      (printf "                      int n1, int n2, int n3 = -1) {\n")
      (printf "    size_t i1 = node_index[n1];\n")
      (printf "    size_t i2 = node_index[n2];\n")
      (printf "    \n")
      (printf "    if (type == \"resistor\") {\n")
      (printf "      double g = 1.0 / value;\n")
      (printf "      G[i1][i1] += g; G[i1][i2] -= g;\n")
      (printf "      G[i2][i1] -= g; G[i2][i2] += g;\n")
      (printf "    } else if (type == \"vsource\") {\n")
      (printf "      // 电压源处理\n")
      (printf "      G[i1][i1] += 1e9;\n")
      (printf "      b[i1] = value * 1e9;\n")
      (printf "    } else if (type == \"capacitor\") {\n")
      (printf "      // 电容处理（暂态）\n")
      (printf "      double g = value / 1e-6; // 假设时间步长1us\n")
      (printf "      G[i1][i1] += g; G[i1][i2] -= g;\n")
      (printf "      G[i2][i1] -= g; G[i2][i2] += g;\n")
      (printf "    }\n")
      (printf "  }\n\n")
      
      (printf "  void build_matrix() {\n")
      (for ([c (circuit-components circ)])
        (printf "    stamp_component(\"~a\", \"~a\", ~a, ~a, ~a"
                (component-type c) (component-id c) (component-value c)
                (first (component-nodes c)) (second (component-nodes c)))
        (when (> (length (component-nodes c)) 2)
          (printf ", ~a" (third (component-nodes c))))
        (printf ");\n"))
      (printf "  }\n\n")
      
      (printf "  void solve() {\n")
      (printf "    // 简单高斯消元（后续可优化）\n")
      (printf "    size_t n = G.size();\n")
      (printf "    for (size_t i = 0; i < n; ++i) {\n")
      (printf "      // 归一化\n")
      (printf "      double pivot = G[i][i];\n")
      (printf "      if (std::abs(pivot) < 1e-12) continue;\n")
      (printf "      for (size_t j = i; j < n; ++j) G[i][j] /= pivot;\n")
      (printf "      b[i] /= pivot;\n")
      (printf "      \n")
      (printf "      // 消元\n")
      (printf "      for (size_t k = i + 1; k < n; ++k) {\n")
      (printf "        double factor = G[k][i];\n")
      (printf "        for (size_t j = i; j < n; ++j) G[k][j] -= factor * G[i][j];\n")
      (printf "        b[k] -= factor * b[i];\n")
      (printf "      }\n")
      (printf "    }\n")
      (printf "    \n")
      (printf "    // 回代\n")
      (printf "    for (int i = n - 1; i >= 0; --i) {\n")
      (printf "      x[i] = b[i];\n")
      (printf "      for (size_t j = i + 1; j < n; ++j) x[i] -= G[i][j] * x[j];\n")
      (printf "    }\n")
      (printf "  }\n\n")
      
      (printf "  void print_results() {\n")
      (printf "    std::cout << \"\\n=== 仿真结果 ===\\n\";\n")
      (for ([p (circuit-probes circ)])
        (printf "    std::cout << \"~a = \" << x[node_index[~a]] << \" V\\n\";\n"
                (probe-name p) (probe-node p)))
      (printf "  }\n")
      
      (printf "};\n\n")
      
      (printf "int main() {\n")
      (printf "  ~a circuit;\n" (string-titlecase (symbol->string (circuit-name circ))))
      (printf "  circuit.initialize();\n")
      (printf "  circuit.build_matrix();\n")
      (printf "  circuit.solve();\n")
      (printf "  circuit.print_results();\n")
      (printf "  return 0;\n")
      (printf "}\n")))
  (printf "🚀 C++ MNA仿真器已生成 → ~a\n" filename))

;; ==================== 提供接口 ====================
(provide define-circuit validate-circuit generate-spice generate-cpp-simulator)

;; ==================== 示例电路库 ====================
(module+ test
  (printf "=== 基础元件完整测试 ===\n\n")
  
  ;; 示例1：RC低通滤波器
  (define-circuit rc-lowpass
    #:title "一阶RC低通滤波器"
    #:analysis (transient #:stop-time 10e-3)
    
    (vsource V1 5.0 (nodes 1 0))
    (resistor R1 1000 (nodes 1 2))
    (capacitor C1 1e-6 (nodes 2 0))
    
    (probe voltage Vout 2))
  
  (validate-circuit rc-lowpass)
  (generate-spice rc-lowpass "rc-lowpass.cir")
  (generate-cpp-simulator rc-lowpass "rc_lowpass_sim.cpp")
  
  (printf "\n")
  
  ;; 示例2：二极管整流电路
  (define-circuit diode-rectifier
    #:title "二极管半波整流器"
    #:analysis (transient #:stop-time 20e-3)
    
    (vsource Vac 12 (nodes 1 0))
    (diode D1 (nodes 1 2))
    (capacitor C1 100e-6 (nodes 2 0))
    (resistor Rload 100 (nodes 2 0))
    
    (probe voltage Vrect 2))
  
  (validate-circuit diode-rectifier)
  (generate-spice diode-rectifier "diode-rectifier.cir")
  (generate-cpp-simulator diode-rectifier "diode_rectifier_sim.cpp")
  
  (printf "\n")
  
  ;; 示例3：运算放大器反相放大器
  (define-circuit opamp-inverting
    #:title "反相运算放大器"
    #:analysis (dc)
    
    (vsource Vin 1.0 (nodes 1 0))
    (resistor Rin 1000 (nodes 1 2))
    (resistor Rf 10000 (nodes 2 3))
    (opamp U1 (nodes 2 0 3))
    
    (probe voltage Vout 3))
  
  (validate-circuit opamp-inverting)
  (generate-spice opamp-inverting "opamp-inverting.cir")
  (generate-cpp-simulator opamp-inverting "opamp_inverting_sim.cpp")
  
  (printf "\n")
  
  ;; 示例4：MOSFET开关电路
  (define-circuit mosfet-switch
    #:title "MOSFET开关电路"
    #:analysis (dc)
    
    (vsource Vdd 12 (nodes 1 0))
    (resistor Rload 100 (nodes 1 2))
    (mosfet M1 (nodes 2 0 3) #:type nmos)
    (vsource Vgs 5 (nodes 3 0))
    
    (probe voltage Vdrain 2))
  
  (validate-circuit mosfet-switch)
  (generate-spice mosfet-switch "mosfet-switch.cir")
  (generate-cpp-simulator mosfet-switch "mosfet_switch_sim.cpp")
  
  (